<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
   >

    <!-- 标题 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:contentPadding="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ 补录记录"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/on_background" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="如果之前忘了记录，可以在这里补填"
        android:textSize="14sp"
        android:textColor="@color/on_surface_variant"
        android:layout_marginTop="4dp" />

    <!-- 补录表单卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:contentPadding="16dp"
        app:cardCornerRadius="16dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <RadioGroup
                android:id="@+id/rgCustomFeedType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rbCustomBreast"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🤱 亲喂" />
                <RadioButton
                    android:id="@+id/rbCustomBottleBreast"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🍶 瓶喂母乳" />
                <RadioButton
                    android:id="@+id/rbCustomFormula"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🍼 配方奶"
                    android:checked="true" />
            </RadioGroup>
            <EditText
                android:id="@+id/etCustomVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="奶量 (ml，亲喂不填)"
                android:inputType="number"
                android:layout_marginTop="8dp" />
            <!-- 日期选择 -->
            <EditText
                android:id="@+id/etCustomDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="日期（点击选择）"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:layout_marginTop="8dp"
                android:drawableStart="@android:drawable/ic_menu_day"
                android:drawablePadding="6dp" />
            <!-- 时间选择 -->
            <EditText
                android:id="@+id/etCustomTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="时间（点击选择）"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:layout_marginTop="4dp"
                android:drawableStart="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="6dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveCustomRecord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📝 保存补录"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>